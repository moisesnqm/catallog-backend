{
  "name": "catallog-backend",
  "version": "1.0.0",
  "description": "Academy backend with RBAC by sector",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "typeorm": "typeorm-ts-node-esm",
    "migration:generate": "typeorm-ts-node-esm -d src/database/data-source.ts migration:generate",
    "migration:run": "tsx src/database/run-migrations.ts",
    "migration:run:prod": "node dist/database/run-migrations.js",
    "migration:revert": "tsx src/database/revert-migration.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.995.0",
    "@clerk/backend": "^1.14.0",
    "@fastify/cors": "^10.0.1",
    "@fastify/multipart": "^9.0.1",
    "@fastify/swagger": "^9.1.0",
    "@fastify/swagger-ui": "^5.0.0",
    "dotenv": "^16.4.5",
    "fastify": "^5.1.0",
    "jose": "^5.9.6",
    "pdf-parse": "^2.4.5",
    "pg": "^8.13.1",
    "reflect-metadata": "^0.2.2",
    "svix": "^1.62.0",
    "typeorm": "^0.3.20",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.23.5"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}

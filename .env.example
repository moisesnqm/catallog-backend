# Database (used by docker-compose and app)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=catallog
POSTGRES_PORT=5432

# App connection (required)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/catallog

# Redis (optional)
REDIS_PORT=6379
# REDIS_URL=redis://localhost:6379

# Clerk (required for protected routes; get from Clerk Dashboard → API Keys / Domains)
# Use your Frontend API domain (no trailing slash). Example for dev:
# CLERK_JWKS_URL=https://<your-instance>.clerk.accounts.dev/.well-known/jwks.json
# CLERK_ISSUER=https://<your-instance>.clerk.accounts.dev
# See docs/backend/CLERK_JWKS.md for details.

# Clerk webhook (optional; for automatic user creation on sign-up / first login)
# Get Signing Secret from Clerk Dashboard → Webhooks → your endpoint. Default tenant must exist in tenants table.
# CLERK_WEBHOOK_SIGNING_SECRET=whsec_...
# CLERK_WEBHOOK_DEFAULT_TENANT_ID=<uuid-of-tenant>
# CLERK_WEBHOOK_DEFAULT_ROLE=viewer
# CLERK_WEBHOOK_DEFAULT_SECTOR_ACCESS=all

# Optional: max upload size (default 10MB), CORS origin, upload dir, public API URL
# UPLOAD_MAX_BYTES=10485760
# CORS_ORIGIN=*
# UPLOAD_STORAGE_PATH=./uploads
# API_PUBLIC_URL=http://localhost:3001
